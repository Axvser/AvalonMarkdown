<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AvalonMarkdown.Views.MarkdownView">
    <DockPanel>
        <!-- ═══════════════════ Error panel (initially hidden) ═══════════════════ -->
        <Border x:Name="ErrorPanel"
                DockPanel.Dock="Bottom"
                Background="#2d1b1b"
                BorderBrush="#5c2a2a"
                BorderThickness="0,1,0,0"
                Padding="12,6"
                IsVisible="False">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Error icon -->
                <TextBlock Grid.Column="0"
                           Text="⚠"
                           Foreground="#f14c4c"
                           FontSize="14"
                           VerticalAlignment="Top"
                           Margin="0,2,8,0"/>
                <!-- Error details -->
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="ErrorTitle"
                               Text="Error"
                               FontWeight="SemiBold"
                               Foreground="#f14c4c"
                               FontSize="12"/>
                    <TextBlock x:Name="ErrorMessage"
                               Text=""
                               TextWrapping="Wrap"
                               Foreground="#d4a0a0"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <!-- Dismiss button -->
                <Button Grid.Column="2"
                        x:Name="DismissErrorButton"
                        Content="✕"
                        FontSize="11"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="#5c2a2a"
                        Foreground="#d4a0a0"
                        Padding="8,2"
                        Margin="12,0,0,0"
                        VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <!-- ═══════════════════ WebView hosting area ═══════════════════ -->
        <Grid x:Name="WebViewHost"/>
    </DockPanel>
</UserControl>
