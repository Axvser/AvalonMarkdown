<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AvalonMarkdown.Views.MarkdownView">
    <DockPanel>
        <!-- ═══════════════════ 顶部工具栏 ═══════════════════ -->
        <Border x:Name="ToolbarPanel"
                DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                <!-- 标题 -->
                <TextBlock Grid.Column="0"
                           Text="Markdown"
                           FontSize="13"
                           Foreground="{DynamicResource SystemAccentColor}"
                           VerticalAlignment="Center"
                           Margin="4,0,12,0"/>

                <Button Grid.Column="1"
                        x:Name="RestartButton"
                        Content="Reload"
                        FontSize="12"
                        Padding="8,2"
                        Margin="2,0"
                        ToolTip.Tip="Reload preview" />

                <Button Grid.Column="2"
                        x:Name="ToggleToolbarButton"
                        Content="Hide"
                        FontSize="12"
                        Padding="8,2"
                        Margin="2,0"
                        ToolTip.Tip="Hide / show toolbar" />

                <!-- 状态指示 -->
                <TextBlock Grid.Column="4"
                           x:Name="StatusText"
                           Text="Loading…"
                           FontSize="11"
                           Foreground="#888"
                           VerticalAlignment="Center"
                           Margin="4,0"/>
            </Grid>
        </Border>

        <!-- ═══════════════════ 错误面板（初始隐藏）═══════════════════ -->
        <Border x:Name="ErrorPanel"
                DockPanel.Dock="Bottom"
                Background="#2d1b1b"
                BorderBrush="#5c2a2a"
                BorderThickness="0,1,0,0"
                Padding="12,6"
                IsVisible="False">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- 错误图标 -->
                <TextBlock Grid.Column="0"
                           Text="⚠"
                           Foreground="#f14c4c"
                           FontSize="14"
                           VerticalAlignment="Top"
                           Margin="0,2,8,0"/>
                <!-- 错误详情 -->
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="ErrorTitle"
                               Text="Error"
                               FontWeight="SemiBold"
                               Foreground="#f14c4c"
                               FontSize="12"/>
                    <TextBlock x:Name="ErrorMessage"
                               Text=""
                               TextWrapping="Wrap"
                               Foreground="#d4a0a0"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <!-- 关闭按钮 -->
                <Button Grid.Column="2"
                        x:Name="DismissErrorButton"
                        Content="✕"
                        FontSize="11"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="#5c2a2a"
                        Foreground="#d4a0a0"
                        Padding="8,2"
                        Margin="12,0,0,0"
                        VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <!-- ═══════════════════ WebView 承载区域 ═══════════════════ -->
        <Grid x:Name="WebViewHost"/>
    </DockPanel>
</UserControl>
