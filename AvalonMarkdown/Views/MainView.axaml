<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvalonMarkdown.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             x:Class="AvalonMarkdown.Views.MainView"
             x:DataType="vm:MainViewModel">

  <Design.DataContext>
    <vm:MainViewModel/>
  </Design.DataContext>

  <!-- MarkdownView 由代码创建后放入 PreviewHost，避免 XAML 提前初始化导致浏览器端多实例 -->
  <Grid ColumnDefinitions="1*, 4, 3*">
    <DockPanel Grid.Column="0" Margin="8">
      <TextBlock DockPanel.Dock="Top" Text="Markdown 编辑器"
                 FontSize="13"
                 Foreground="{DynamicResource SystemAccentColor}"
                 Margin="0,0,0,6"/>
      <TextBox x:Name="MarkdownEditor"
               Text="{Binding MarkdownText, Mode=TwoWay}"
               TextWrapping="NoWrap"
               AcceptsReturn="True" AcceptsTab="True"
               FontSize="13"
               Background="#1e1e1e" Foreground="#d4d4d4"
               BorderThickness="1" BorderBrush="#3c3c3c"
               Padding="8"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
    </DockPanel>
    <Rectangle Grid.Column="1" Fill="#3c3c3c" Width="4"/>
    <Grid x:Name="PreviewHost" Grid.Column="2" Margin="8"/>
  </Grid>
</UserControl>
