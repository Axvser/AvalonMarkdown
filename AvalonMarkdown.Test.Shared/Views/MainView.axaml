<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="clr-namespace:AvalonMarkdown.Views;assembly=AvalonMarkdown"
             xmlns:vm="using:AvalonMarkdown.Test.Shared.ViewModels"
             x:Class="AvalonMarkdown.Test.Shared.Views.MainView"
             x:DataType="vm:MainViewModel">
    <DockPanel>
        <!-- ═══════ Toolbar: Preset samples + multi-view toggle + timing ═══════ -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource SystemAccentColor}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Presets:"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>
                <Button Grid.Column="1"
                        x:Name="SimplePresetButton"
                        Content="Simple"
                        FontSize="11" Padding="6,2" Margin="2,0"/>
                <Button Grid.Column="2"
                        x:Name="FullPresetButton"
                        Content="Full"
                        FontSize="11" Padding="6,2" Margin="2,0"/>
                <Button Grid.Column="3"
                        x:Name="BigDocPresetButton"
                        Content="Big Doc"
                        FontSize="11" Padding="6,2" Margin="2,0"/>

                <Separator Grid.Column="4" Width="1" Height="16"
                           Background="#3c3c3c" Margin="8,0" VerticalAlignment="Center"/>

                <Button Grid.Column="5"
                        x:Name="MultiViewToggle"
                        Content="Single"
                        FontSize="11" Padding="8,2"
                        ToolTip.Tip="Toggle single/multi-view comparison mode"/>

                <!-- Single view timing info -->
                <TextBlock Grid.Column="6"
                           x:Name="TimingText"
                           Text="{Binding TimingInfo}"
                           FontSize="11"
                           Foreground="#888"
                           VerticalAlignment="Center"
                           Margin="4,0"/>
            </Grid>
        </Border>

        <!-- ═══════ Single view mode ═══════ -->
        <Grid x:Name="SingleView" Margin="8" RowDefinitions="Auto,8,*">
            <TextBox x:Name="MarkdownEditor"
                     Text="{Binding MarkdownText}"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     MinHeight="120"
                     MaxHeight="300"
                     FontSize="13" />
            <md:MarkdownView x:Name="Preview" Grid.Row="2" />
        </Grid>

        <!-- ═══════ Multi-view mode (3 instances side by side) ═══════ -->
        <Grid x:Name="MultiView" Margin="8" IsVisible="False"
              ColumnDefinitions="*,4,*">
            <!-- Left column: Simple -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           x:Name="TimingText1"
                           Text="{Binding TimingInfo}"
                           FontSize="11" Foreground="#888"
                           Margin="0,0,0,4"/>
                <md:MarkdownView x:Name="Preview1" Grid.Row="1" />
            </Grid>

            <Rectangle Grid.Column="1" Fill="#3c3c3c" Width="4" IsHitTestVisible="False"/>

            <!-- Right column: split vertically (Full + Big Doc) -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,4,Auto,*">
                <TextBlock Grid.Row="0"
                           x:Name="TimingText2"
                           Text="{Binding TimingInfo2}"
                           FontSize="11" Foreground="#888"
                           Margin="0,0,0,4"/>
                <md:MarkdownView x:Name="Preview2" Grid.Row="1" />

                <Rectangle Grid.Row="2" Fill="#3c3c3c" Height="4" IsHitTestVisible="False"/>

                <TextBlock Grid.Row="3"
                           x:Name="TimingText3"
                           Text="{Binding TimingInfo3}"
                           FontSize="11" Foreground="#888"
                           Margin="0,4,0,0"/>
                <md:MarkdownView x:Name="Preview3" Grid.Row="4" />
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
