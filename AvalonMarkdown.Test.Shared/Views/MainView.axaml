<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="clr-namespace:AvalonMarkdown.Views;assembly=AvalonMarkdown"
             xmlns:vm="using:AvalonMarkdown.Test.Shared.ViewModels"
             x:Class="AvalonMarkdown.Test.Shared.Views.MainView"
             x:DataType="vm:MainViewModel">
    <DockPanel>
        <Grid DockPanel.Dock="Top" Margin="8" RowDefinitions="Auto,8,*">
            <TextBox x:Name="MarkdownEditor"
                     Text="{Binding MarkdownText}"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     MinHeight="120"
                     MaxHeight="300"
                     FontSize="13" />
            <md:MarkdownView x:Name="Preview"
                             Grid.Row="2" />
        </Grid>
    </DockPanel>
</UserControl>
