<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AvalonMarkdown.Test.Shared"
             x:Class="AvalonMarkdown.Test.Shared.App"
             RequestedThemeVariant="Default">
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <!-- Global text element default font: Inter first, Microsoft YaHei as Chinese fallback -->
        <Style Selector="TextElement">
            <Setter Property="FontFamily"
                    Value="Inter, Microsoft YaHei" />
        </Style>
    </Application.Styles>
</Application>
